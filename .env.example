APP_NAME=Mummish
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Google / social preview defaults (optional overrides — see config/seo.php for taglines)
# SEO_TITLE="Mummish | Marketplace for mothers & kids in Ghana"
# SEO_DESCRIPTION="Marketplace for the modern mother. Shop baby clothes, kids products, and family essentials from trusted local sellers across Ghana."

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DAILY_DAYS=30
LOG_HTTP_REQUESTS=false
LOG_QUERY_LOGGING=false
LOG_SLOW_REQUEST_MS=1000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Tests use sqlite :memory: via phpunit.xml. Do not run `php artisan test` against your dev DB without that isolation.

# Filament admin (/admin)
# Preferred: php artisan admin:setup-link  → open the one-time URL (collects each admin's own phone)
# Or seed a bootstrap admin, then add more under Admin → Admin users
ADMIN_EMAIL=admin@mummish.com
ADMIN_PASSWORD=password
ADMIN_NAME=Admin
# Optional bootstrap phone for AdminUserSeeder only (each admin should set their own at registration)
ADMIN_PHONE=0201854694

# SMS alerts for marketplace ops (comma-separated). Not used for password reset.
ADMIN_NOTIFICATION_PHONE=0208062426

# Max product listings while vendor application is pending (null = no cap)
VENDOR_MAX_LISTINGS_WHILE_PENDING=2

# Platform fee on vendor sales (basis points: 1000 = 10%)
VENDOR_COMMISSION_BPS=1000

# Default vendor referral payouts (pesewas / basis points). Per-referrer overrides in admin.
VENDOR_REFERRAL_REGISTRATION_REWARD_CENTS=50
VENDOR_REFERRAL_COMMISSION_BPS=200

# Product image quality (technical checks on vendor upload)
# PRODUCT_MIN_IMAGES=3
# PRODUCT_IMAGE_MIN_WIDTH=800
# PRODUCT_IMAGE_MIN_HEIGHT=800
# PRODUCT_IMAGE_MIN_SHARPNESS=80

# Checkout shipping fallback in pesewas when no region/city rate matches (GHS 0.00 = 0)
CHECKOUT_SHIPPING_CENTS=0
# Temporary: waive all delivery fees for testing (set false / remove before production deploy)
SHIPPING_FREE=false
# Region shipping defaults (pesewas). Per-city overrides: config/shipping_rates_by_city.json
# SHIPPING_GREATER_ACCRA_CENTS=1500
# SHIPPING_ASHANTI_CENTS=2500

# Paystack — https://paystack.com/docs/
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# PAYSTACK_PAYMENT_URL=https://api.paystack.co

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="info@themummish.com"
MAIL_FROM_NAME="${APP_NAME}"

# Public support inbox shown on FAQ, shipping, privacy, etc.
SUPPORT_EMAIL=info@themummish.com
SUPPORT_PHONE=0208062428

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# BMS API v2 — https://developer.mnotify.com/ (Quick SMS: POST …/api/sms/quick?key=…)
MNOTIFY_SMS_API_KEY=
MNOTIFY_SENDER_ID=
# MNOTIFY_SMS_ENDPOINT=https://api.mnotify.com/api/sms/quick
